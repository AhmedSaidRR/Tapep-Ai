# ════════════════════════════════════════════════════════════
#  MediBlaze / Tapep AI — Environment Variables
#  Copy this file to .env and fill in your actual API keys.
#  NEVER commit the real .env file to version control!
# ════════════════════════════════════════════════════════════

# ── Google AI (Gemini) ───────────────────────────────────────
# Used for: chat LLM, image/vision analysis, drug interaction checks
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_ai_api_key_here

# ── Pinecone ─────────────────────────────────────────────────
# Used for: RAG knowledge base (vector search)
# Get from: https://www.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# ── Groq ─────────────────────────────────────────────────────
# Used for: fallback LLM (llama-3.3-70b-versatile)
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ── Supabase ─────────────────────────────────────────────────
# Used for: user authentication + cloud sync
# Get from: https://supabase.com/ (Project Settings → API)
# NOTE: Use .supabase.co (NOT .supabase.com)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# In development use: http://localhost:8000
# In production replace with your actual domain(s).
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Server ───────────────────────────────────────────────────
# Port for the FastAPI server (Railway sets this automatically)
PORT=8000
